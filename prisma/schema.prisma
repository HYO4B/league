generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Division {
  id            String     @id @default(cuid())
  name          String
  season        String
  tier          Int
  pointsCorrect Int        @default(3)
  pointsWrong   Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  teams         Team[]
  questions     Question[]

  @@index([tier])
  @@unique([season, tier, name])
}

model Team {
  id         String      @id @default(cuid())
  divisionId String
  name       String
  provider   String?
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  division   Division    @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  predictions Prediction[]

  @@unique([divisionId, name])
  @@index([divisionId])
}

model Question {
  id              String       @id @default(cuid())
  divisionId      String
  title           String
  description     String?
  openAt          DateTime     @default(now())
  closeAt         DateTime?
  resolvedAt      DateTime?
  correctOptionId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  division        Division     @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  options         Option[]
  predictions     Prediction[]
  correctOption   Option?      @relation("CorrectOption", fields: [correctOptionId], references: [id])

  @@index([divisionId])
  @@index([resolvedAt])
}

model Option {
  id         String      @id @default(cuid())
  questionId String
  label      String
  order      Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  predictions Prediction[]
  correctFor Question[]  @relation("CorrectOption")

  @@unique([questionId, order])
  @@index([questionId])
}

model Prediction {
  id         String   @id @default(cuid())
  teamId     String
  questionId String
  optionId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option     Option   @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([teamId, questionId])
  @@index([questionId])
  @@index([teamId])
}
